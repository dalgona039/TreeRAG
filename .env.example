# Example environment variables for TreeRAG
# Copy this to .env and fill values (do NOT commit .env)

# Google API key used by backend (replace with your key)
GOOGLE_API_KEY=your-google-api-key-here

# Traversal settings
USE_DEEP_TRAVERSAL=true
MAX_TRAVERSAL_DEPTH=5
MAX_BRANCHES_PER_LEVEL=3

# Redis URL (when running via docker-compose the service name 'redis' is available)
REDIS_URL=redis://redis:6379/0

# Frontend base URL
NEXT_PUBLIC_API_BASE_URL=http://backend:8000/api
# Google Gemini API Key
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_api_key_here
