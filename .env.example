# Example environment variables for TreeRAG
# Copy this to .env and fill values (do NOT commit .env)

# ============================================================
# Google Gemini API Key 설정
# 키 발급: https://aistudio.google.com/app/apikey
# ============================================================

# [필수] 기본 API key — 아래 케이스별 키가 없으면 이 키로 fallback됩니다.
GOOGLE_API_KEY=your_api_key_here

# [선택] 케이스별 API key — 다른 Google 계정의 키를 사용해 비용/할당량을 분산할 수 있습니다.
# 지정하지 않은 케이스는 GOOGLE_API_KEY를 사용합니다.
#
# PDF → JSON 트리 변환 (indexer.py) — 문서당 1회 실행, 호출 많음
#GOOGLE_API_KEY_INDEXING=your_indexing_key_here
#
# 트리 탐색 (tree_traversal.py, beam_search.py) — 쿼리마다 다수 호출
#GOOGLE_API_KEY_TRAVERSAL=your_traversal_key_here
#
# 최종 답변 생성 및 라우팅 (reasoner.py, routes.py, document_router_service.py)
#GOOGLE_API_KEY_REASONING=your_reasoning_key_here
#
# 추론 그래프 구축 (reasoning_graph.py) — 선택적 기능
#GOOGLE_API_KEY_GRAPH=your_graph_key_here
#
# 벤치마크 평가 (domain_benchmark.py) — 개발/테스트 시에만 사용
#GOOGLE_API_KEY_BENCHMARK=your_benchmark_key_here

# ============================================================
# Traversal 설정
# ============================================================
USE_DEEP_TRAVERSAL=true
MAX_TRAVERSAL_DEPTH=5
MAX_BRANCHES_PER_LEVEL=3

# Redis URL (docker-compose 사용 시 'redis' 서비스명 사용 가능)
REDIS_URL=redis://redis:6379/0

# Frontend API 주소
NEXT_PUBLIC_API_BASE_URL=http://backend:8000/api
